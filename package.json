{
  "name": "sizuku",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:dist": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "dev:desktop": "SIZUKU_MENU_BAR_MODE=0 tauri dev",
    "dev:menubar": "SIZUKU_MENU_BAR_MODE=1 tauri dev",
    "build:desktop": "SIZUKU_MENU_BAR_MODE=0 tauri build",
    "build:menubar": "SIZUKU_MENU_BAR_MODE=1 tauri build --config src-tauri/tauri.menubar.conf.json",
    "build": "npm run build:desktop && npm run build:menubar"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-store": "^2.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
